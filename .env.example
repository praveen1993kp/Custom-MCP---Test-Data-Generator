# Database Configuration for MySQL/Opentaps
# Copy this file to .env and fill in your actual database credentials

# MySQL Database Host
DB_HOST=localhost

# MySQL Database Port (default: 3306)
DB_PORT=3306

# MySQL Database User
DB_USER=your_username

# MySQL Database Password
DB_PASSWORD=your_password

# MySQL Database Name (Opentaps schema)
DB_NAME=opentaps

# Environment (development | production)
NODE_ENV=development
